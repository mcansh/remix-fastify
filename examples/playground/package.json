{
  "name": "playground",
  "private": true,
  "description": "",
  "license": "",
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "start": "cross-env NODE_ENV=production node ./server.js",
    "lint": "eslint --ignore-path .gitignore --no-error-on-unmatched-pattern --cache --cache-location node_modules/.cache/eslint --fix .",
    "format": "prettier --ignore-path .gitignore --ignore-unknown --cache --cache-location node_modules/.cache/prettiercache --write .",
    "typecheck": "react-router typegen && tsc",
    "validate": "run-p lint format typecheck"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "@mcansh/remix-fastify": "workspace:",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@react-router/node": "latest",
    "chalk": "^5.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fastify": "^5.8.5",
    "get-port": "^7.2.0",
    "isbot": "^5.1.40",
    "lucide-react": "^1.17.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router": "latest",
    "source-map-support": "^0.5.21",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@fastify/middie": "^9.3.2",
    "@react-router/dev": "latest",
    "@remix-run/eslint-config": "latest",
    "@tailwindcss/vite": "4.3.0",
    "@total-typescript/tsconfig": "^1.0.4",
    "@types/node": "^25.9.1",
    "@types/react": "npm:types-react@19.0.0-alpha.3",
    "@types/react-dom": "npm:types-react-dom@19.0.0-alpha.3",
    "@types/source-map-support": "^0.5.10",
    "chokidar": "^5.0.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.4.1",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "4.3.0",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "overrides": {
    "@types/react": "$@types/react",
    "@types/react-dom": "$@types/react-dom",
    "react": "$react",
    "react-dom": "$react-dom"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
