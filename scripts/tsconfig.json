{
  "include": ["."],
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "forceConsistentCasingInFileNames": true,
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "nodenext",
    "module": "NodeNext",
    "noEmit": true,
    "strict": true,
    "target": "ESNext",
    "lib": ["ESNext", "DOM"],
    "types": ["node"]
  }
}
