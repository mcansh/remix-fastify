{
  "name": "@mcansh/remix-fastify",
  "version": "4.1.2",
  "description": "Fastify server request handler and Vite dev plugin for React Router v7",
  "keywords": [
    "fastify",
    "react-router",
    "vite"
  ],
  "bugs": {
    "url": "https://github.com/mcansh/remix-fastify/issues"
  },
  "license": "MIT",
  "author": "Logan McAnsh <logan@mcan.sh> (https://mcan.sh)",
  "repository": "mcansh/remix-fastify",
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/mcansh"
    }
  ],
  "files": [
    "dist",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./vite": "./dist/vite.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "prepublishOnly": "npm run build",
    "typecheck": "tsc",
    "dev": "tsdown --watch",
    "build": "tsdown",
    "test": "vitest",
    "validate": "run-p typecheck test"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "@remix-run/headers": "^0.21.1",
    "fastify-plugin": "^5.1.0"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.3",
    "@react-router/node": "^7.17.0",
    "@types/node": "^25.9.1",
    "@typescript/lib-dom": "npm:@types/web@^0.0.237",
    "fastify": "^5.8.5",
    "node-mocks-http": "^1.17.2",
    "publint": "^0.3.21",
    "react-router": "^7.17.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  },
  "peerDependencies": {
    "@react-router/node": "^7.0.0",
    "fastify": "^3.29.0 || ^4.0.0 || ^5.0.0",
    "react-router": "^7.0.0",
    "vite": "^5.0.0-0 || ^6.0.0-0 || ^7.0.0-0 || ^8.0.0-0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
